generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
}

model Repo {
 id        String   @id @default(cuid())
 name      String
 githubUrl String
 files     File[]
 createdAt DateTime @default(now())
}

model File {
 id        String   @id @default(cuid())
 path      String
 language  String
 repoId    String
 repo      Repo     @relation(fields: [repoId], references: [id])
 functions Function[]
}

model Function {
 id        String @id @default(cuid())
 name      String
 code      String
 startLine Int
 endLine   Int
 fileId    String
 file      File   @relation(fields: [fileId], references: [id])
}